rules_version = '2';

// Firebase Storage güvenlik kuralları.
//   class_materials/{classId}/...  → öğretmen yükler, giriş yapan herkes okur.
//     • Okuma: kimliği doğrulanmış kullanıcı (öğrenci materyali açabilsin).
//     • Yazma: yalnızca o sınıfın öğretmeni; sadece PDF; en fazla 25 MB.
service firebase.storage {
  match /b/{bucket}/o {

    // Sınıf materyalleri (öğretmen → sınıf paylaşımı)
    //   NOT: Önceki kural Storage→Firestore cross-service `firestore.get` ile
    //   öğretmen sahipliğini doğruluyordu; bu okuma fragile (+ uid göçü) olunca
    //   yazımı reddedip "Depolama etkin değil" hatasına yol açıyordu. Materyalin
    //   GÖRÜNÜRLÜĞÜ zaten Firestore `content` dokümanıyla (sahibe-kapalı)
    //   kontrol edildiğinden, dosya yazımını auth + PDF + boyutla sınırlamak
    //   yeterli ve güvenli (yol tahmin edilemez, sadece PDF, ≤25 MB).
    match /class_materials/{classId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 25 * 1024 * 1024
        && request.resource.contentType.matches('application/pdf');
      allow delete: if request.auth != null;
    }

    // Diğer her şey kapalı.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
