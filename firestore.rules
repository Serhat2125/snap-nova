rules_version = '2';

// ═══════════════════════════════════════════════════════════════════════════
//  QuAlsar — Production Firestore Security Rules
//  Firebase Console → Firestore → Rules sekmesine YAPIŞTIRIN.
//  `firebase deploy --only firestore:rules` ile de gönderebilirsiniz.
// ═══════════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Yardımcı fonksiyonlar ─────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn()
        && request.auth.token.admin == true;
    }

    // İstek sahibi, `childUid`'e AKTİF olarak bağlı bir ebeveyn mi?
    // parent_links/{parentUid}/children/{childUid}.status == 'active'
    // Ebeveyn paneli (Gelişim Paneli) bağlı çocuğun verisini bu sayede okur.
    function isLinkedParent(childUid) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/parent_links/$(request.auth.uid)/children/$(childUid))
        && get(/databases/$(database)/documents/parent_links/$(request.auth.uid)/children/$(childUid)).data.status == 'active';
    }

    // ── app_errors: istemciler sadece yazabilir ──────────────────────────
    //    Okuma sadece admin. Hata raporları dışarı açılmaz.
    match /app_errors/{doc} {
      allow create: if true;          // anonim kullanıcı da hata gönderebilir
      allow read, update, delete: if isAdmin();
    }

    // ── config/runtime: herkes okur, sadece admin yazar ──────────────────
    //    Uzaktan yapılandırma (RemoteConfigService) bu koleksiyonu okur.
    match /config/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── feedback: kullanıcılar gönderir, sadece admin okur ──────────────
    match /feedback/{doc} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // ── İçerik bildirimleri: kullanıcılar gönderir, sadece admin okur ─────
    //    inappropriate_reports → uygunsuz/saldırgan AI çıktısı (Gen-AI politikası)
    //    incorrect_reports     → yanlış AI cevabı (kalite iyileştirme)
    match /inappropriate_reports/{doc} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
    match /incorrect_reports/{doc} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // ── users/{uid}: kullanıcı profili (arkadaş araması için public read) ─
    //    Read: oturum açmış herkes (username search, profil önizleme).
    //    Write: sadece sahibi.
    //    Alt koleksiyonlar (solved_problems, mastery vb.) sadece sahibi okur/yazar.
    //    İSTİSNA: `premium/*` doc'ları sadece Cloud Function (admin SDK) yazar.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isOwner(uid);

      // ⚠️ Premium subscription state — yalnızca server (admin SDK) yazabilir.
      //    Client sadece okur. Bu kural recursive /{sub=**} kuralından
      //    ÖNCE değil — Firestore "any allow wins" kullandığı için
      //    aşağıdaki recursive rule içinde `sub` regex'iyle premium
      //    yazımı bloklanıyor. Buradaki block sadece okuma izni veriyor.
      match /premium/{doc=**} {
        allow read: if isOwner(uid);
        allow write: if false; // admin SDK bu kurala tabi değildir
      }

      // Alt koleksiyonlar (solved_problems, mastery, achievements vb.)
      //    Premium hariç — recursive wildcard `path` tipinde döner, string'e
      //    çevirip ilk segment kontrolü yapıyoruz. Premium yazımı bu kuralda
      //    reddedilir; sadece üstteki `match /premium/{doc=**}` rule
      //    (allow write: if false) geçerli olur — yani client yazamaz.
      match /{sub=**} {
        // Sahibi her zaman; ayrıca AKTİF bağlı ebeveyn salt-okur (panel için).
        allow read: if isOwner(uid) || isLinkedParent(uid);
        allow write: if isOwner(uid)
          && !string(sub).matches('premium(/.*)?');
      }
    }

    // ── friends/{uid}/list/{friendUid}: iki yönlü arkadaşlık edge'i ────────
    //    Read: sadece sahibi (kendi listesini görür).
    //    Write: hem sahibi (uid) HEM de karşı taraf (friendUid) yazabilir —
    //           çünkü acceptRequest() iki yönlü edge'i tek batch'te oluşturur.
    match /friends/{uid}/list/{friendUid} {
      allow read: if isOwner(uid);
      allow create, update, delete:
        if isOwner(uid) || isOwner(friendUid);
    }

    // ── friend_requests/{toUid}/inbox/{fromUid}: arkadaşlık istekleri ─────
    //    Read: sadece alıcı (toUid).
    //    Create: gönderen (fromUid) kendi isteğini yazabilir.
    //    Update: alıcı (status = accepted/rejected) veya admin.
    //    Delete: alıcı veya admin.
    match /friend_requests/{toUid}/inbox/{fromUid} {
      allow read: if isOwner(toUid);
      allow create: if isOwner(fromUid)
        && request.resource.data.fromUid == request.auth.uid;
      allow update: if isOwner(toUid);
      allow delete: if isOwner(toUid) || isAdmin();
    }

    // ── notifications/{uid}/items/{auto}: in-app bildirimler ──────────────
    //    Read: sahibi.
    //    Create: herhangi bir oturum açmış kullanıcı (X kullanıcı Y'ye
    //            arkadaşlık isteği gönderirken Y'nin inbox'ına bildirim yazar).
    //    Update: sadece sahibi (read flag).
    //    Delete: sahibi.
    match /notifications/{uid}/items/{nid} {
      allow read: if isOwner(uid);
      allow create: if isSignedIn();
      allow update, delete: if isOwner(uid);
    }

    // ── duelo_invites/{targetUid}/inbox/{auto}: arkadaşa düello daveti ────
    //    Read: hedef kullanıcı.
    //    Create: oturum açmış herkes (davet gönderir).
    //    Update: hedef (accept/reject).
    match /duelo_invites/{targetUid}/inbox/{iid} {
      allow read: if isOwner(targetUid);
      allow create: if isSignedIn();
      allow update, delete: if isOwner(targetUid);
    }

    // ── matchmaking_queue: Bilgi Yarışı eşleşme kuyruğu ──────────────────
    //    Eşleşme için kullanıcılar birbirinin "waiting" doc'unu okur; eşleşen
    //    taraf karşının doc'unu status=matched yapar. userId alanı cihaz-bazlı
    //    duelo id (auth uid değil) olduğundan auth eşleşmesi zorlanamaz —
    //    oturum açmış olmak yeterli.
    match /matchmaking_queue/{id} {
      allow read, create, update, delete: if isSignedIn();
    }

    // ── duelo_sessions: gerçek senkron düello oturumu ────────────────────
    //    İki katılımcı session'ı okur; owner soruları, her oyuncu kendi
    //    ilerlemesini yazar. (Davet session'ını CF admin SDK ile açar.)
    match /duelo_sessions/{sid} {
      allow read, create, update: if isSignedIn();
    }

    // ── presence: çevrimiçi işareti (best-effort) ────────────────────────
    match /presence/{uid} {
      allow read, write: if isSignedIn();
    }

    // ── rematch_requests: rövanş isteği ──────────────────────────────────
    match /rematch_requests/{id} {
      allow read, create: if isSignedIn();
    }

    // ── leaderboards: herkes okur, sadece admin ya da Cloud Functions yazar
    match /leaderboards/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── league_attempts: Bilgi Ligi quiz sonuçları ────────────────────────
    //    Read: oturum açmış herkes (liderlik tablosu için).
    //    Create: sadece doküman içindeki uid eşleşiyorsa (kendi attempt'ı).
    //    Update/Delete: kendi dokümanı + admin.
    //
    //    Cheat koruması:
    //      • score number (int OR double — ondalık net hesabı için)
    //      • 0 ≤ score ≤ 10 (tek quiz max 10 net)
    //      • durationSec 5..3600 (10 saniyeden hızlı = bot; 1 saat üstü =
    //        idle/manipülasyon)
    //      • subjectKey ve when ZORUNLU (eksiksiz kayıt)
    match /league_attempts/{doc} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.score is number
        && request.resource.data.score >= 0
        && request.resource.data.score <= 10
        && request.resource.data.durationSec is number
        && request.resource.data.durationSec >= 5
        && request.resource.data.durationSec <= 3600
        && request.resource.data.subjectKey is string
        && request.resource.data.subjectKey.size() > 0;
      // Update YASAK (score sonradan değiştirilemez) — sadece silme veya admin.
      allow update: if isAdmin();
      allow delete: if isOwner(resource.data.uid) || isAdmin();
    }

    // ── quiz_pool: AI'la üretilen test havuzu ─────────────────────────────
    //    Read:   oturum açmış herkes (havuzdan random çekiş için).
    //    Create: oturum açmış kullanıcı; createdBy alanı uid ile eşleşmeli.
    //            Havuz cap (>=100 ise yeni eklenmez) istemci tarafında
    //            kontrol edilir; rules sadece base güvenliği sağlar.
    //    Update/Delete: sadece admin (havuz değişmesin, sadece eklensin).
    match /quiz_pool/{doc} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ── arena_matches/{id}: taraflar okur; sadece katılanlar yazar ──────
    match /arena_matches/{id} {
      allow read: if isSignedIn()
        && (request.auth.uid in resource.data.participants);
      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.participants;
      allow update: if isSignedIn()
        && request.auth.uid in resource.data.participants;
    }

    // ── referral_codes/{CODE}: davet kodu → ownerUid lookup tablosu ──────
    //    Read: oturum açmış herkes (kod doğrulamak için).
    //    Create: oturum açmış kullanıcı kendi uid'sini owner olarak yazabilir.
    //    Update/Delete: sadece admin.
    match /referral_codes/{code} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ── referrals/{ownerUid}: kişinin davet ettiği kullanıcıların listesi
    //    Read: oturum açmış herkes (UI davet stats için).
    //    Write: sahibi VEYA Firestore transaction içinden davet eden kullanıcı
    //           (kendisini ownerUid'nin invitedUsers'ına eklemek için
    //           arrayUnion). Anti-fraud production'da Cloud Function ile
    //           yapılmalıdır; bu rules MVP için yeterli.
    match /referrals/{ownerUid} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isOwner(ownerUid) || isAdmin();
    }

    // ── summary_cache: topluluk özet havuzu ──────────────────────────────
    //   Parent doc: herkes okur (cache key bazlı arama).
    //   /candidates/{cid}: oturum açmış kullanıcı yeni aday ekleyebilir;
    //   rating ve report güncellemeleri için kısıtlı update izni.
    //   canonicalDocId ve status: SADECE Cloud Function (judge) yazar.
    match /summary_cache/{key} {
      allow read: if true;
      // Parent doc kullanıcı tarafından create/update edilir
      // (candidateCount increment, basic meta). status/canonicalDocId
      // SADECE judge function tarafından yazılır (rules guard).
      allow create: if isSignedIn();
      allow update: if isSignedIn()
        && !(request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['status', 'canonicalDocId', 'judgeStats',
                       'canonicalSelectedAt', 'judgedAt']));
      allow delete: if isAdmin();

      match /candidates/{cid} {
        allow read: if true;
        allow create: if isSignedIn()
          && request.resource.data.body is string
          && request.resource.data.body.size() > 50
          && request.resource.data.body.size() < 10000;
        // Rating / report güncellemesi — yalnızca belirli alanlar
        allow update: if isSignedIn()
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['ratings', 'ratingsByUser', 'reportCount', 'reports']);
        allow delete: if isAdmin();
      }
    }

    // ── question_pool: 5000 soruluk havuz ────────────────────────────────
    //   Read: herkes (havuzdan çekme).
    //   Write: SADECE Cloud Function (generator) + admin.
    //   Kullanıcı timesServed/errorReports field'larını update edebilir.
    match /question_pool/{key} {
      allow read: if true;
      // Init için tek kez kullanıcı create eder (boş parent doc).
      // Generator/admin diğer tüm yazımları yapar.
      allow create: if isSignedIn();
      allow update: if isAdmin()
        || (isSignedIn() && request.resource.data.diff(resource.data)
            .affectedKeys().hasOnly(['updatedAt']));
      allow delete: if isAdmin();

      match /questions/{qid} {
        allow read: if true;
        allow create: if isAdmin(); // SADECE Cloud Function generator
        allow update: if isSignedIn()
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['timesServed', 'errorReports', 'reports']);
        allow delete: if isAdmin();
      }
    }

    // ── rate_limits: Cloud Function rate-limiter (kullanıcı yazamaz) ─────
    match /rate_limits/{doc} {
      allow read, write: if isAdmin();
    }

    // ── purchaseTokens/{token}: Google Play purchaseToken → uid mapping ───
    //   RTDN webhook'un user'ı bulması için. Client kendi uid'sini yazar,
    //   sadece admin (Cloud Function) okur. Token başlı başına bir secret
    //   olduğu için read'i kapatıyoruz (kötü niyetli kullanıcı tüm token-uid
    //   eşlemelerini listeleyemesin).
    match /purchaseTokens/{token} {
      allow read: if isAdmin();
      allow create, update: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ── parent_links/{parentUid}/children/{childUid}: bağlı çocuklar ─────
    //   Ebeveyn kendi list'ini okur/yazar; aktif bağlantı = çocuk onaylamış.
    //   Çocuk istek geldiğinde durumu 'active'e çevirebilir (özel update).
    match /parent_links/{parentUid}/children/{childUid} {
      allow read: if isOwner(parentUid) || isOwner(childUid);
      // Ebeveyn pending istek oluşturabilir
      allow create: if isOwner(parentUid)
        && request.resource.data.status == 'pending';
      // Çocuk kabul/red — sadece status değişikliği
      allow update: if (isOwner(childUid) || isOwner(parentUid))
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'acceptedAt']);
      // Ebeveyn bağlantıyı sonlandırabilir
      allow delete: if isOwner(parentUid);
    }

    // ── child_invites/{childUid}/from/{parentUid}: çocuğun gelen kutusu ──
    //   Çocuk istekleri okur + status değiştirir.
    //   Ebeveyn create yapar.
    match /child_invites/{childUid}/from/{parentUid} {
      allow read: if isOwner(childUid) || isOwner(parentUid);
      allow create: if isOwner(parentUid)
        && request.resource.data.status == 'pending';
      allow update: if isOwner(childUid)
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'acceptedAt']);
      allow delete: if isOwner(childUid) || isOwner(parentUid);
    }

    // ── parent_link_codes/{code}: çocuğun ürettiği kısa-ömürlü eşleşme kodu ─
    //   Çocuk kendi kodunu üretir (childUid == kendisi). Ebeveyn kodu okuyup
    //   childUid'i bulur, sonra siler. Kod yalnızca childUid + zaman içerir;
    //   veri erişimi yine ÇOCUĞUN ONAYINA bağlı (sadece kod yetki vermez).
    match /parent_link_codes/{code} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.childUid == request.auth.uid;
      allow delete: if isSignedIn();
    }

    // ── classes/{classId}: öğretmen sınıfı ────────────────────────────────
    //   Read: oturum açmış herkes (sınıf detayını öğrenci de görür).
    //   Create: oturum açan herkes (kendisini teacherUid olarak yazmalı).
    //   Update/Delete: sadece öğretmen.
    match /classes/{classId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.teacherUid == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.teacherUid == request.auth.uid;

      // students alt koleksiyonu — öğrenci kendini ekler, öğretmen yönetir
      //   (öğretmen ayrıca demo öğrenci ekleyebilir → önizleme/test için).
      match /students/{studentUid} {
        allow read: if isSignedIn();
        allow create: if isOwner(studentUid)
          || (isSignedIn()
              && get(/databases/$(database)/documents/classes/$(classId))
                  .data.teacherUid == request.auth.uid);
        allow delete: if isOwner(studentUid)
          || (isSignedIn()
              && get(/databases/$(database)/documents/classes/$(classId))
                  .data.teacherUid == request.auth.uid);
        allow update: if isSignedIn()
          && get(/databases/$(database)/documents/classes/$(classId))
              .data.teacherUid == request.auth.uid;

        // grades alt koleksiyonu — öğrencinin yazılı/sözlü notları.
        //   Read: öğrencinin kendisi, bağlı ebeveyni VE sınıf öğretmeni.
        //   Write: SADECE sınıf öğretmeni.
        match /grades/{gradeId} {
          allow read: if isOwner(studentUid)
            || isLinkedParent(studentUid)
            || (isSignedIn()
                && get(/databases/$(database)/documents/classes/$(classId))
                    .data.teacherUid == request.auth.uid);
          allow create, update, delete: if isSignedIn()
            && get(/databases/$(database)/documents/classes/$(classId))
                .data.teacherUid == request.auth.uid;
        }

        // notes alt koleksiyonu — öğretmenin öğrenci hakkındaki notları.
        //   Read: sınıf öğretmeni (tümü) ve öğrencinin kendisi/ebeveyni
        //   YALNIZCA sharedWithParent==true olan notları görebilir
        //   (öğretmene özel gözlemler sızmasın).
        //   Write: SADECE sınıf öğretmeni.
        match /notes/{noteId} {
          allow read: if (isSignedIn()
                && get(/databases/$(database)/documents/classes/$(classId))
                    .data.teacherUid == request.auth.uid)
            || ((isOwner(studentUid) || isLinkedParent(studentUid))
                && resource.data.sharedWithParent == true);
          allow create, update, delete: if isSignedIn()
            && get(/databases/$(database)/documents/classes/$(classId))
                .data.teacherUid == request.auth.uid;
        }
      }

      // content alt koleksiyonu — sadece öğretmen ekler, öğrenciler okur
      match /content/{contentId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isSignedIn()
          && get(/databases/$(database)/documents/classes/$(classId))
              .data.teacherUid == request.auth.uid;
      }

      // homeworks alt koleksiyonu — sadece öğretmen oluşturur/yönetir,
      //   sınıftaki öğrenciler okur (ödevi çözmek için).
      match /homeworks/{homeworkId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isSignedIn()
          && get(/databases/$(database)/documents/classes/$(classId))
              .data.teacherUid == request.auth.uid;

        // submissions — her öğrenci KENDİ submission'ını okur/yazar;
        //   öğretmen (sınıf sahibi) sınıfın tüm submission'larını okur;
        //   bağlı EBEVEYN de çocuğunun teslimlerini okur (ödev takibi için).
        match /submissions/{studentUid} {
          allow read: if isOwner(studentUid)
            || isLinkedParent(studentUid)
            || (isSignedIn()
                && get(/databases/$(database)/documents/classes/$(classId))
                    .data.teacherUid == request.auth.uid);
          // Öğrenci yalnızca kendi submission'ını yazar; öğretmen
          //   ödev dağıtırken (assignToClass) pending slot açabilir.
          allow create, update: if isOwner(studentUid)
            || (isSignedIn()
                && get(/databases/$(database)/documents/classes/$(classId))
                    .data.teacherUid == request.auth.uid);
          allow delete: if isSignedIn()
            && get(/databases/$(database)/documents/classes/$(classId))
                .data.teacherUid == request.auth.uid;
        }
      }
    }

    // ── class_codes/{code}: kod → classId reverse index ──────────────────
    //   Öğrenci koddan classId bulmak için okur; öğretmen create eder.
    match /class_codes/{code} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.teacherUid == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.teacherUid == request.auth.uid;
    }

    // NOT: notifications kuralı yukarıda (satır ~106) tek noktada tanımlı.

    // ── Varsayılan: reddet ───────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
