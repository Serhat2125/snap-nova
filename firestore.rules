rules_version = '2';

// ═══════════════════════════════════════════════════════════════════════════
//  QuAlsar — Production Firestore Security Rules
//  Firebase Console → Firestore → Rules sekmesine YAPIŞTIRIN.
//  `firebase deploy --only firestore:rules` ile de gönderebilirsiniz.
// ═══════════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Yardımcı fonksiyonlar ─────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn()
        && request.auth.token.admin == true;
    }

    // İstek sahibi, `childUid`'e AKTİF olarak bağlı bir ebeveyn mi?
    // parent_links/{parentUid}/children/{childUid}.status == 'active'
    // Ebeveyn paneli (Gelişim Paneli) bağlı çocuğun verisini bu sayede okur.
    function isLinkedParent(childUid) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/parent_links/$(request.auth.uid)/children/$(childUid))
        && get(/databases/$(database)/documents/parent_links/$(request.auth.uid)/children/$(childUid)).data.status == 'active';
    }

    // ── app_errors: istemciler sadece yazabilir ──────────────────────────
    //    Okuma sadece admin. Hata raporları dışarı açılmaz.
    match /app_errors/{doc} {
      allow create: if true;          // anonim kullanıcı da hata gönderebilir
      allow read, update, delete: if isAdmin();
    }

    // ── config/runtime: herkes okur, sadece admin yazar ──────────────────
    //    Uzaktan yapılandırma (RemoteConfigService) bu koleksiyonu okur.
    match /config/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── feedback: kullanıcılar gönderir, sadece admin okur ──────────────
    match /feedback/{doc} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // ── İçerik bildirimleri: kullanıcılar gönderir, sadece admin okur ─────
    //    inappropriate_reports → uygunsuz/saldırgan AI çıktısı (Gen-AI politikası)
    //    incorrect_reports     → yanlış AI cevabı (kalite iyileştirme)
    match /inappropriate_reports/{doc} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
    match /incorrect_reports/{doc} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
    //    question_error_reports → havuz sorusu "hatalı" bildirimi (düz kopya;
    //    günlük admin özeti dailyReportDigest CF buradan sayar)
    match /question_error_reports/{doc} {
      allow create: if isSignedIn()
        && request.resource.data.poolKey is string
        && request.resource.data.questionId is string
        && request.resource.data.reason is string
        && request.resource.data.reason.size() < 500;
      allow read, update, delete: if isAdmin();
    }

    // ── users/{uid}: kullanıcı profili (arkadaş araması için public read) ─
    //    Read: oturum açmış herkes (username search, profil önizleme).
    //    Write: sadece sahibi.
    //    Alt koleksiyonlar (solved_problems, mastery vb.) sadece sahibi okur/yazar.
    //    İSTİSNA: `premium/*` doc'ları sadece Cloud Function (admin SDK) yazar.
    match /users/{uid} {
      allow read: if isSignedIn();
      // accountType yalnızca bilinen üç rolden biri olabilir (değer doğrulama).
      // Sert immutability YOK: uygulama içi onaylı "hesap tipini değiştir"
      // akışı (parent_dashboard) client'tan yazar; yetkiler zaten accountType
      // alanından değil sahiplik/teacherUid kurallarından türer.
      allow delete: if isOwner(uid);
      allow create, update: if isOwner(uid)
        && (!request.resource.data.keys().hasAny(['accountType'])
            || request.resource.data.accountType in ['student', 'parent', 'teacher']);

      // ⚠️ Premium subscription state — yalnızca server (admin SDK) yazabilir.
      //    Client sadece okur. Bu kural recursive /{sub=**} kuralından
      //    ÖNCE değil — Firestore "any allow wins" kullandığı için
      //    aşağıdaki recursive rule içinde `sub` regex'iyle premium
      //    yazımı bloklanıyor. Buradaki block sadece okuma izni veriyor.
      match /premium/{doc=**} {
        allow read: if isOwner(uid);
        allow write: if false; // admin SDK bu kurala tabi değildir
      }

      // Alt koleksiyonlar (solved_problems, mastery, achievements vb.)
      //    Premium hariç — recursive wildcard `path` tipinde döner, string'e
      //    çevirip ilk segment kontrolü yapıyoruz. Premium yazımı bu kuralda
      //    reddedilir; sadece üstteki `match /premium/{doc=**}` rule
      //    (allow write: if false) geçerli olur — yani client yazamaz.
      match /{sub=**} {
        // Sahibi her zaman; ayrıca AKTİF bağlı ebeveyn salt-okur (panel için).
        allow read: if isOwner(uid) || isLinkedParent(uid);
        allow write: if isOwner(uid)
          && !string(sub).matches('premium(/.*)?');
      }
    }

    // ── usernames/{name}: kullanıcı adı benzersizlik rezervasyonu ──────────
    //   doc.id = lowercase username, data.uid = sahip. Atomik claim için.
    //   create: yalnızca kendi adına; Firestore create => doc YOKsa başarılı,
    //           böylece eşzamanlı iki kişi aynı adı alamaz (gerçek benzersizlik).
    //   delete: yalnızca sahibi — ad değiştirince eski rezervasyonu bırakmak için.
    //   update: yasak (sahiplik devredilemez).
    match /usernames/{name} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // ── friends/{uid}/list/{friendUid}: iki yönlü arkadaşlık edge'i ────────
    //    Read: sadece sahibi (kendi listesini görür).
    //    Write: hem sahibi (uid) HEM de karşı taraf (friendUid) yazabilir —
    //           çünkü acceptRequest() iki yönlü edge'i tek batch'te oluşturur.
    match /friends/{uid}/list/{friendUid} {
      allow read: if isOwner(uid);
      allow create, update, delete:
        if isOwner(uid) || isOwner(friendUid);
    }

    // ── friend_requests/{toUid}/inbox/{fromUid}: arkadaşlık istekleri ─────
    //    Read: sadece alıcı (toUid).
    //    Create: gönderen (fromUid) kendi isteğini yazabilir.
    //    Update: alıcı (status = accepted/rejected) veya admin.
    //    Delete: alıcı veya admin.
    match /friend_requests/{toUid}/inbox/{fromUid} {
      allow read: if isOwner(toUid);
      allow create: if isOwner(fromUid)
        && request.resource.data.fromUid == request.auth.uid;
      allow update: if isOwner(toUid);
      allow delete: if isOwner(toUid) || isAdmin();
    }

    // ── notifications/{uid}/items/{auto}: in-app bildirimler ──────────────
    //    Read: sahibi.
    //    Create: herhangi bir oturum açmış kullanıcı (X kullanıcı Y'ye
    //            arkadaşlık isteği gönderirken Y'nin inbox'ına bildirim yazar).
    //    Update: sadece sahibi (read flag).
    //    Delete: sahibi.
    match /notifications/{uid}/items/{nid} {
      allow read: if isOwner(uid);
      allow create: if isSignedIn();
      allow update, delete: if isOwner(uid);
    }

    // ── duelo_invites/{targetUid}/inbox/{auto}: arkadaşa düello daveti ────
    //    Read: hedef kullanıcı.
    //    Create: oturum açmış herkes (davet gönderir).
    //    Update: hedef (accept/reject).
    match /duelo_invites/{targetUid}/inbox/{iid} {
      allow read: if isOwner(targetUid);
      allow create: if isSignedIn();
      allow update, delete: if isOwner(targetUid);
    }

    // ── matchmaking_queue: Bilgi Yarışı eşleşme kuyruğu ──────────────────
    //    Eşleşme için kullanıcılar birbirinin "waiting" doc'unu okur; eşleşen
    //    taraf karşının doc'unu status=matched yapar. userId alanı cihaz-bazlı
    //    duelo id (auth uid değil) olduğundan auth eşleşmesi zorlanamaz —
    //    oturum açmış olmak yeterli.
    match /matchmaking_queue/{id} {
      allow read, create, update, delete: if isSignedIn();
    }

    // ── duelo_sessions: gerçek senkron düello oturumu ────────────────────
    //    İki katılımcı session'ı okur; owner soruları, her oyuncu kendi
    //    ilerlemesini yazar. (Davet session'ını CF admin SDK ile açar.)
    match /duelo_sessions/{sid} {
      allow read, create, update: if isSignedIn();
    }

    // ── presence: çevrimiçi işareti (best-effort) ────────────────────────
    match /presence/{uid} {
      allow read, write: if isSignedIn();
    }

    // ── rematch_requests: rövanş isteği ──────────────────────────────────
    match /rematch_requests/{id} {
      allow read, create: if isSignedIn();
    }

    // ── leaderboards: herkes okur, sadece admin ya da Cloud Functions yazar
    match /leaderboards/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── league_attempts: Bilgi Ligi quiz sonuçları ────────────────────────
    //    Read: oturum açmış herkes (liderlik tablosu için).
    //    Write: İSTEMCİYE TAMAMEN KAPALI — tek yazım yolu
    //    `submitLeagueAttempt` Cloud Function'ıdır (admin SDK, rules'a tabi
    //    değil). Fonksiyon rate limit + sunucu saati kovası + idempotens +
    //    attempt↔totals atomikliği uygular; istemci yazımı açık kalsaydı
    //    bunların hepsi API ile aşılabilirdi.
    //    (Hesap silme de deleteAccount function'ı ile — admin SDK.)
    match /league_attempts/{doc} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // ── app_config: uzaktan kontrol bayrakları (demo dolgu vb.) ───────────
    //    Read: herkes (giriş öncesi de gerekebilir). Write: yalnız admin /
    //    Cloud Functions (autoDisableLeagueDemo 10k eşiğinde demoEnabled'ı
    //    kapatır).
    match /app_config/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── league_totals: Bilgi Ligi toplam puan dokümanları ─────────────────
    //    Kullanıcı × takvim kovası × mod başına increment'li toplam; sıralama
    //    sorguları doğrudan bunu okur (10 bin+ kullanıcıda kesin sonuç).
    //    Write: İSTEMCİYE KAPALI — yalnızca submitLeagueAttempt /
    //    updateLeagueDisplayName Cloud Function'ları yazar (admin SDK).
    match /league_totals/{doc} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // ── quiz_pool: AI'la üretilen test havuzu ─────────────────────────────
    //    Read:  oturum açmış herkes (havuzdan random çekiş için).
    //    Write: İSTEMCİYE KAPALI — tek yazım yolu `addQuizPoolTest` Cloud
    //           Function'ıdır (admin SDK): şema doğrulama + transaction'lı
    //           kesin havuz tavanı (100) + rate limit. İstemci yazımı açık
    //           kaldığında tavan yalnız istemcide denetleniyordu → API ile
    //           sınırsız çöp soru basılabiliyordu (içerik zehirlenmesi).
    match /quiz_pool/{doc} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // ── quiz_pool_counters: havuz başına test sayacı (CF transaction'ı) ──
    match /quiz_pool_counters/{doc} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── arena_matches/{id}: taraflar okur; sadece katılanlar yazar ──────
    match /arena_matches/{id} {
      allow read: if isSignedIn()
        && (request.auth.uid in resource.data.participants);
      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.participants;
      allow update: if isSignedIn()
        && request.auth.uid in resource.data.participants;
    }

    // ── referral_codes/{CODE}: davet kodu → ownerUid lookup tablosu ──────
    //    Read: oturum açmış herkes (kod doğrulamak için).
    //    Create: oturum açmış kullanıcı kendi uid'sini owner olarak yazabilir.
    //    Update/Delete: sadece admin.
    match /referral_codes/{code} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ── referrals/{ownerUid}: kişinin davet ettiği kullanıcıların listesi
    //    Read: oturum açmış herkes (UI davet stats için).
    //    Write: sahibi VEYA Firestore transaction içinden davet eden kullanıcı
    //           (kendisini ownerUid'nin invitedUsers'ına eklemek için
    //           arrayUnion). Anti-fraud production'da Cloud Function ile
    //           yapılmalıdır; bu rules MVP için yeterli.
    match /referrals/{ownerUid} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isOwner(ownerUid) || isAdmin();
    }

    // ── summary_cache: topluluk özet havuzu ──────────────────────────────
    //   Parent doc: herkes okur (cache key bazlı arama).
    //   /candidates/{cid}: oturum açmış kullanıcı yeni aday ekleyebilir;
    //   rating ve report güncellemeleri için kısıtlı update izni.
    //   canonicalDocId ve status: SADECE Cloud Function (judge) yazar.
    match /summary_cache/{key} {
      allow read: if true;
      // Parent doc kullanıcı tarafından create/update edilir
      // (candidateCount increment, basic meta). status/canonicalDocId
      // SADECE judge function tarafından yazılır (rules guard).
      allow create: if isSignedIn();
      allow update: if isSignedIn()
        && !(request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['status', 'canonicalDocId', 'judgeStats',
                       'canonicalSelectedAt', 'judgedAt']));
      allow delete: if isAdmin();

      match /candidates/{cid} {
        allow read: if true;
        allow create: if isSignedIn()
          && request.resource.data.body is string
          && request.resource.data.body.size() > 50
          && request.resource.data.body.size() < 10000;
        // Rating / report güncellemesi — yalnızca belirli alanlar
        allow update: if isSignedIn()
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['ratings', 'ratingsByUser', 'reportCount', 'reports']);
        allow delete: if isAdmin();
      }
    }

    // ── question_pool: 5000 soruluk havuz ────────────────────────────────
    //   Read: herkes (havuzdan çekme).
    //   Write: SADECE Cloud Function (generator) + admin.
    //   Kullanıcı timesServed/errorReports field'larını update edebilir.
    match /question_pool/{key} {
      allow read: if true;
      // Init için tek kez kullanıcı create eder (boş parent doc).
      // Generator/admin diğer tüm yazımları yapar.
      allow create: if isSignedIn();
      allow update: if isAdmin()
        || (isSignedIn() && request.resource.data.diff(resource.data)
            .affectedKeys().hasOnly(['updatedAt']));
      allow delete: if isAdmin();

      match /questions/{qid} {
        allow read: if true;
        // CF generator (admin) + istemci ORGANİK doluş (insertQuestions —
        // AI'ın ürettiği test havuza yazılır ki sonraki öğrenci AI beklemesin).
        // Eski hali admin-only idi → organik doluş sessizce reddediliyordu;
        // labirent_pool ile aynı şema-doğrulamalı create'e açıldı.
        allow create: if isAdmin()
          || (isSignedIn()
            && request.resource.data.stem is string
            && request.resource.data.stem.size() >= 20
            && request.resource.data.stem.size() < 2000
            && request.resource.data.options is list
            && request.resource.data.options.size() >= 2
            && request.resource.data.options.size() <= 5
            && request.resource.data.correctIndex is int
            && request.resource.data.correctIndex >= 0
            && request.resource.data.correctIndex
                < request.resource.data.options.size());
        allow update: if isSignedIn()
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['timesServed', 'errorReports', 'reports']);
        allow delete: if isAdmin();
      }
    }

    // ── labirent_pool: Bilgi Labirenti topluluk içerik havuzu ────────────
    //   Read: herkes (havuzdan çekme). Parent doc: kullanıcı init edebilir,
    //   sayaçları organik doluşta artırabilir. İçerik (q/f): imzalı kullanıcı
    //   ŞEMA DOĞRULAMALI create edebilir (organik doluş) — CF judge/admin
    //   temizler; update/delete yalnız admin.
    match /labirent_pool/{key} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin()
        || (isSignedIn() && request.resource.data.diff(resource.data)
            .affectedKeys().hasOnly(['questionCount', 'factCount', 'updatedAt']));
      allow delete: if isAdmin();

      match /q/{qid} {
        allow read: if true;
        allow create: if isAdmin()
          || (isSignedIn()
            && request.resource.data.q is string
            && request.resource.data.q.size() >= 10
            && request.resource.data.q.size() < 2000
            && request.resource.data.opts is list
            && request.resource.data.opts.size() >= 3
            && request.resource.data.opts.size() <= 5
            && request.resource.data.a is int
            && request.resource.data.a >= 0
            && request.resource.data.a < request.resource.data.opts.size());
        allow update, delete: if isAdmin();
      }

      match /f/{fid} {
        allow read: if true;
        allow create: if isAdmin()
          || (isSignedIn()
            && request.resource.data.t is string
            && request.resource.data.t.size() >= 10
            && request.resource.data.t.size() < 400);
        allow update, delete: if isAdmin();
      }
    }

    // ── rate_limits: Cloud Function rate-limiter (kullanıcı yazamaz) ─────
    match /rate_limits/{doc} {
      allow read, write: if isAdmin();
    }

    // ── purchaseTokens/{token}: Google Play purchaseToken → uid mapping ───
    //   RTDN webhook'un user'ı bulması için. Client kendi uid'sini yazar,
    //   sadece admin (Cloud Function) okur. Token başlı başına bir secret
    //   olduğu için read'i kapatıyoruz (kötü niyetli kullanıcı tüm token-uid
    //   eşlemelerini listeleyemesin).
    match /purchaseTokens/{token} {
      allow read: if isAdmin();
      allow create, update: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ── parent_links/{parentUid}/children/{childUid}: bağlı çocuklar ─────
    //   Ebeveyn kendi list'ini okur/yazar; aktif bağlantı = çocuk onaylamış.
    //   Çocuk istek geldiğinde durumu 'active'e çevirebilir (özel update).
    match /parent_links/{parentUid}/children/{childUid} {
      allow read: if isOwner(parentUid) || isOwner(childUid);
      // İki create yolu — kendini çocuk olarak EKLEYEMEZ (rol değiştiren
      // hesap kendi verisine "veli" olarak bağlanamasın):
      //  (a) username akışı: 'pending' istek, çocuk banner'dan onaylar.
      //  (b) kod/QR akışı: geçerli parent_link_codes/{viaCode} ibrazı rıza
      //      sayılır (kodu üreten/paylaşan çocuğun kendisi) → DOĞRUDAN
      //      'active' create edilebilir; kod hedef çocuğa ait ve süresi
      //      geçmemiş olmalı.
      allow create: if isOwner(parentUid)
        && parentUid != childUid
        && (request.resource.data.status == 'pending'
            || (request.resource.data.status == 'active'
                && request.resource.data.viaCode is string
                && get(/databases/$(database)/documents/parent_link_codes/$(request.resource.data.viaCode)).data.childUid == childUid
                && get(/databases/$(database)/documents/parent_link_codes/$(request.resource.data.viaCode)).data.expiresAt > request.time));
      // Çocuk kabul/red — sadece status değişikliği
      allow update: if (isOwner(childUid) || isOwner(parentUid))
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'acceptedAt']);
      // Ebeveyn bağlantıyı sonlandırabilir
      allow delete: if isOwner(parentUid);
    }

    // ── child_invites/{childUid}/from/{parentUid}: çocuğun gelen kutusu ──
    //   Çocuk istekleri okur + status değiştirir.
    //   Ebeveyn create yapar.
    match /child_invites/{childUid}/from/{parentUid} {
      allow read: if isOwner(childUid) || isOwner(parentUid);
      // parent_links ile aynı iki yol: 'pending' (username) veya geçerli
      // viaCode kanıtıyla doğrudan 'active' (kod/QR akışı).
      allow create: if isOwner(parentUid)
        && parentUid != childUid
        && (request.resource.data.status == 'pending'
            || (request.resource.data.status == 'active'
                && request.resource.data.viaCode is string
                && get(/databases/$(database)/documents/parent_link_codes/$(request.resource.data.viaCode)).data.childUid == childUid
                && get(/databases/$(database)/documents/parent_link_codes/$(request.resource.data.viaCode)).data.expiresAt > request.time));
      allow update: if isOwner(childUid)
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'acceptedAt']);
      allow delete: if isOwner(childUid) || isOwner(parentUid);
    }

    // ── parent_link_codes/{code}: çocuğun ürettiği kısa-ömürlü eşleşme kodu ─
    //   Çocuk kendi kodunu üretir (childUid == kendisi; QR/WhatsApp ile
    //   veliye ulaştırır). Ebeveyn kodu okuyup childUid'i bulur; geçerli kod
    //   ibrazı = çocuğun rızası → parent_links/child_invites create'inde
    //   viaCode kanıtıyla DOĞRUDAN 'active' bağlantıya izin verilir.
    //   Kod kullanılınca ebeveyn tarafından silinir (tek kullanımlık).
    match /parent_link_codes/{code} {
      // get: kodu ibraz eden veli childUid'i çözer (doc id'yi BİLMEK şart).
      allow get: if isSignedIn();
      // list: yalnız KENDİ kodlarını sorgulayan çocuk — eskiden `read` hem
      // get hem list'e izin veriyordu: oturum açan herkes TÜM aktif kodları
      // listeleyip rastgele çocuklara "veli" olarak bağlanabilirdi (kodun
      // tahmin edilemezliği anlamsızlaşıyordu).
      allow list: if isSignedIn()
        && resource.data.childUid == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.childUid == request.auth.uid;
      // delete: kodu üreten çocuk YA DA kodu az önce tüketip bağlanan veli
      // (bağlantı dokümanı mevcut) — eskiden herkes herkesin kodunu silip
      // bağlanmayı engelleyebiliyordu.
      allow delete: if isSignedIn()
        && (resource.data.childUid == request.auth.uid
            || exists(/databases/$(database)/documents/parent_links/$(request.auth.uid)/children/$(resource.data.childUid)));
    }

    // ── classes/{classId}: öğretmen sınıfı ────────────────────────────────
    //   Read: oturum açmış herkes (sınıf detayını öğrenci de görür).
    //   Create: oturum açan herkes (kendisini teacherUid olarak yazmalı).
    //   Update/Delete: sadece öğretmen.
    match /classes/{classId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.teacherUid == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.teacherUid == request.auth.uid;

      // students alt koleksiyonu — öğrenci kendini ekler, öğretmen yönetir
      //   (öğretmen ayrıca demo öğrenci ekleyebilir → önizleme/test için).
      match /students/{studentUid} {
        // Eskiden isSignedIn() — HERHANGİ bir kullanıcı herhangi bir sınıfın
        // öğrenci listesini (isim/foto/ülke) çekebiliyordu. Artık yalnız:
        // öğrencinin kendisi, bağlı velisi ve sınıf öğretmeni.
        allow read: if isOwner(studentUid)
          || isLinkedParent(studentUid)
          || (isSignedIn()
              && get(/databases/$(database)/documents/classes/$(classId))
                  .data.teacherUid == request.auth.uid);
        // Öğrencinin KENDİNİ eklemesi: ya 'pending' (kodla katılım, öğretmen
        // onaylar) ya da öğretmenin yazdığı davet kanıtı (invites/{uid})
        // mevcutsa doğrudan 'active'. Eskiden status hiç doğrulanmıyordu —
        // classId'yi bilen herkes onay adımını atlayıp 'active' yazabiliyordu.
        allow create: if (isOwner(studentUid)
              && (request.resource.data.status == 'pending'
                  || exists(/databases/$(database)/documents/classes/$(classId)/invites/$(studentUid))))
          || (isSignedIn()
              && get(/databases/$(database)/documents/classes/$(classId))
                  .data.teacherUid == request.auth.uid);
        allow delete: if isOwner(studentUid)
          || (isSignedIn()
              && get(/databases/$(database)/documents/classes/$(classId))
                  .data.teacherUid == request.auth.uid);
        allow update: if isSignedIn()
          && get(/databases/$(database)/documents/classes/$(classId))
              .data.teacherUid == request.auth.uid;

        // grades alt koleksiyonu — öğrencinin yazılı/sözlü notları.
        //   Read: öğrencinin kendisi, bağlı ebeveyni VE sınıf öğretmeni.
        //   Write: SADECE sınıf öğretmeni.
        match /grades/{gradeId} {
          allow read: if isOwner(studentUid)
            || isLinkedParent(studentUid)
            || (isSignedIn()
                && get(/databases/$(database)/documents/classes/$(classId))
                    .data.teacherUid == request.auth.uid);
          allow create, update: if isSignedIn()
            && get(/databases/$(database)/documents/classes/$(classId))
                .data.teacherUid == request.auth.uid;
          // delete: öğretmen VE (sınıftan ayrılırken kendi verisini
          // temizleyen) öğrencinin kendisi — leaveClass yetim not bırakmasın.
          allow delete: if isOwner(studentUid)
            || (isSignedIn()
                && get(/databases/$(database)/documents/classes/$(classId))
                    .data.teacherUid == request.auth.uid);
        }

        // notes alt koleksiyonu — öğretmenin öğrenci hakkındaki notları.
        //   Read: sınıf öğretmeni (tümü) ve öğrencinin kendisi/ebeveyni
        //   YALNIZCA sharedWithParent==true olan notları görebilir
        //   (öğretmene özel gözlemler sızmasın).
        //   Write: SADECE sınıf öğretmeni.
        match /notes/{noteId} {
          allow read: if (isSignedIn()
                && get(/databases/$(database)/documents/classes/$(classId))
                    .data.teacherUid == request.auth.uid)
            || ((isOwner(studentUid) || isLinkedParent(studentUid))
                && resource.data.sharedWithParent == true);
          allow create, update: if isSignedIn()
            && get(/databases/$(database)/documents/classes/$(classId))
                .data.teacherUid == request.auth.uid;
          // delete: öğretmen VE sınıftan ayrılan öğrencinin kendisi
          // (leaveClass temizliği — yetim not kalmasın).
          allow delete: if isOwner(studentUid)
            || (isSignedIn()
                && get(/databases/$(database)/documents/classes/$(classId))
                    .data.teacherUid == request.auth.uid);
        }
      }

      // invites — öğretmenin kalıcı davet kanıtı: students create kuralı bu
      // dokümanın varlığına bakarak davetli öğrencinin doğrudan 'active'
      // katılmasına izin verir (bildirim tek başına kanıt DEĞİLDİR; öğrenci
      // kendi inbox'una sahte bildirim yazabilir).
      match /invites/{studentUid} {
        allow read: if isOwner(studentUid)
          || (isSignedIn()
              && get(/databases/$(database)/documents/classes/$(classId))
                  .data.teacherUid == request.auth.uid);
        allow create, update: if isSignedIn()
          && get(/databases/$(database)/documents/classes/$(classId))
              .data.teacherUid == request.auth.uid;
        // Davetli öğrenci katılınca kanıtı kendisi temizleyebilir.
        allow delete: if isOwner(studentUid)
          || (isSignedIn()
              && get(/databases/$(database)/documents/classes/$(classId))
                  .data.teacherUid == request.auth.uid);
      }

      // content alt koleksiyonu — sadece öğretmen ekler; SINIFIN AKTİF
      // öğrencileri okur. Eskiden isSignedIn() — sınıftan çıkarılan/hiç
      // katılmamış herkes classId ile tüm kaynakları okuyabiliyordu.
      // (status alanı olmayan eski üyelik kayıtları 'active' sayılır.)
      match /content/{contentId} {
        allow read: if isSignedIn()
          && (get(/databases/$(database)/documents/classes/$(classId))
                  .data.teacherUid == request.auth.uid
              || get(/databases/$(database)/documents/classes/$(classId)/students/$(request.auth.uid))
                  .data.get('status', 'active') == 'active');
        allow create, update, delete: if isSignedIn()
          && get(/databases/$(database)/documents/classes/$(classId))
              .data.teacherUid == request.auth.uid;
      }

      // scheduled_announcements — öğretmenin ileri tarihe zamanladığı duyurular.
      //   Yalnızca sınıf öğretmeni yazar; yayın anında bir scheduled function
      //   (publishScheduledAnnouncements) bunları gerçek bildirime çevirir.
      match /scheduled_announcements/{annId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isSignedIn()
          && get(/databases/$(database)/documents/classes/$(classId))
              .data.teacherUid == request.auth.uid;
      }

      // homeworks alt koleksiyonu — sadece öğretmen oluşturur/yönetir,
      //   sınıftaki öğrenciler okur (ödevi çözmek için).
      match /homeworks/{homeworkId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isSignedIn()
          && get(/databases/$(database)/documents/classes/$(classId))
              .data.teacherUid == request.auth.uid;

        // submissions — her öğrenci KENDİ submission'ını okur/yazar;
        //   öğretmen (sınıf sahibi) sınıfın tüm submission'larını okur;
        //   bağlı EBEVEYN de çocuğunun teslimlerini okur (ödev takibi için).
        match /submissions/{studentUid} {
          allow read: if isOwner(studentUid)
            || isLinkedParent(studentUid)
            || (isSignedIn()
                && get(/databases/$(database)/documents/classes/$(classId))
                    .data.teacherUid == request.auth.uid);
          // Öğrenci yalnızca kendi submission'ını yazar; öğretmen
          //   ödev dağıtırken (assignToClass) pending slot açabilir.
          allow create, update: if isOwner(studentUid)
            || (isSignedIn()
                && get(/databases/$(database)/documents/classes/$(classId))
                    .data.teacherUid == request.auth.uid);
          // delete: öğretmen VE sınıftan ayrılırken kendi teslimini
          // temizleyen öğrenci (leaveClass — yetim submission "hayalet
          // öğrenci" satırı üretiyordu).
          allow delete: if isOwner(studentUid)
            || (isSignedIn()
                && get(/databases/$(database)/documents/classes/$(classId))
                    .data.teacherUid == request.auth.uid);
        }
      }
    }

    // ── class_codes/{code}: kod → classId reverse index ──────────────────
    //   Öğrenci koddan classId bulmak için okur; öğretmen create eder.
    match /class_codes/{code} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.teacherUid == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.teacherUid == request.auth.uid;
    }

    // NOT: notifications kuralı yukarıda (satır ~106) tek noktada tanımlı.

    // ── parental_controls/{childUid}/byParent/{parentUid}: ebeveyn kontrolü
    //   (süre/sessiz saat), EBEVEYN BAZLI alt-koleksiyon. Önceden tek paylaşılan
    //   doküman (parental_controls/{childUid}) idi — birden fazla ebeveyn (anne+
    //   baba) bağlıyken biri diğerinin ayarını sessizce eziyordu. Artık her
    //   ebeveyn KENDİ dokümanına yazar; çocuk cihazı TÜM ebeveynlerin
    //   dokümanlarını okuyup en kısıtlayıcısını uygular (ParentalControlsService).
    match /parental_controls/{childUid} {
      match /byParent/{parentUid} {
        allow read: if isOwner(childUid) || isLinkedParent(childUid);
        allow write: if isLinkedParent(childUid) && parentUid == request.auth.uid
          && request.resource.data.parentUid == request.auth.uid;
        allow delete: if isLinkedParent(childUid) && parentUid == request.auth.uid;
      }
    }

    // ── group_contests/{id}: arkadaş grubu yarışması (özel lig) ──────────
    //   Read: oturum açmış herkes (davet linki/QR ile gelen katılabilsin,
    //         soruları okuyabilsin, sıralamayı görebilsin).
    //   Create: oturum açmış kullanıcı; ownerUid kendisi olmalı.
    //   Update/Delete: sadece sahibi (yarışmayı kuran).
    match /group_contests/{contestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.ownerUid == request.auth.uid;

      // participants/{uid}: her katılımcı KENDİ doc'unu yazar (doc.id = uid).
      //   Read: oturum açmış herkes (lobi + sıralama).
      //   Create/Update: sadece kendi uid'i; score int ve >= 0.
      //   Delete: kendisi veya yarışma sahibi.
      match /participants/{uid} {
        allow read: if isSignedIn();
        allow create, update: if isOwner(uid)
          && request.resource.data.score is int
          && request.resource.data.score >= 0;
        allow delete: if isOwner(uid)
          || (isSignedIn()
              && get(/databases/$(database)/documents/group_contests/$(contestId))
                  .data.ownerUid == request.auth.uid);
      }
    }

    // ── Collection-group: participants ────────────────────────────────────
    // "Yarışlarım → Grup Arkadaşımla Yarışlarım" sekmesi kullanıcının
    // katıldığı yarışları collectionGroup('participants') ile bulur.
    // Yukarıdaki İÇ İÇE match collection-group sorgularını YETKİLENDİRMEZ
    // (Firestore kuralı) — bu blok olmadan sorgu permission-denied alıyor
    // ve sekme sessizce hep boş görünüyordu. Okuma zaten üstte tüm oturum
    // açmışlara açık; burada da aynı seviye verilir, yazma verilmez.
    match /{path=**}/participants/{uid} {
      allow read: if isSignedIn();
    }

    // ── contest_groups/{id}: KAYITLI yarışma grupları ─────────────────────
    //   (group_contests = tekil yarışma; contest_groups = isimlendirilip
    //    saklanan arkadaş grubu — İKİSİ AYRI koleksiyon. Bu blok eksikti ve
    //    varsayılan-reddet yüzünden grup oluşturma/katılma tamamen ölüydü.)
    //   Read: oturum açmış herkes (davetli üyeler grubu görebilsin).
    //   Create: ownerUid kendisi olmalı ve kendisi üye listesinde olmalı
    //           (sahip, QR/kullanıcı adıyla seçtiği üyeleri de baştan yazar).
    //   Update: sahibi HER ŞEYİ günceller; sahibi olmayan yalnızca
    //           memberUids/members/updatedAt alanlarına dokunarak KENDİNİ
    //           ekleyebilir (davetten katıl) veya çıkarabilir (gruptan ayrıl).
    //   Delete: sadece sahibi.
    match /contest_groups/{groupId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.auth.uid in request.resource.data.memberUids;
      allow update: if isSignedIn() && (
        resource.data.ownerUid == request.auth.uid
        || (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['memberUids', 'members', 'updatedAt'])
          && (
            // Kendini EKLEME (join): önce yoktu, sonra var.
            (!(request.auth.uid in resource.data.memberUids)
              && request.auth.uid in request.resource.data.memberUids)
            // Kendini ÇIKARMA (leave): önce vardı, sonra yok.
            || (request.auth.uid in resource.data.memberUids
              && !(request.auth.uid in request.resource.data.memberUids))
          )
        )
      );
      allow delete: if isSignedIn()
        && resource.data.ownerUid == request.auth.uid;
    }

    // ── Collection-group: users/*/referral (anti-fraud cihaz kontrolü) ───
    //   ReferralService.redeemCode collectionGroup('referral') ile TÜM
    //   kullanıcıların referral/state dokümanlarında deviceHash arar.
    //   CG sorguları üstteki users/{uid}/{sub=**} kuralından İZİN ALMAZ —
    //   bu kural olmadan sorgu permission-denied yiyor ve davet kodu
    //   kullanımı tamamen başarısız oluyordu. İçerik hassas değil
    //   (usedCode + cihaz hash'i); yazma yine sadece sahibinde.
    match /{path=**}/referral/{doc} {
      allow read: if isSignedIn();
    }

    // ── lesson_packs: indirilebilir dil paketi manifest'i ────────────────
    //   { version, count, path, status } — küçük, hassas değil. İstemci
    //   diline göre okur; yazma yalnızca sunucu (admin SDK) → istemci kapalı.
    match /lesson_packs/{lang} {
      allow read: if true;
      allow write: if false;
    }

    // ── Varsayılan: reddet ───────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
