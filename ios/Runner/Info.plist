		</dict>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>com.qualsar.ai</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>qualsar</string>
			</array>
		</dict>
	</array>
	<!-- FCM push + Universal Links + Pomodoro alarm sesi arka plan teslimat -->
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
		<string>remote-notification</string>
		<string>audio</string>
	</array>
