{
  "indexes": [
    {
      "collectionGroup": "app_errors",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "fatal", "order": "DESCENDING" },
        { "fieldPath": "timestamp", "order": "DESCENDING" }
      ]
    },
    {
      "collectionGroup": "app_errors",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "instanceId", "order": "ASCENDING" },
        { "fieldPath": "timestamp", "order": "DESCENDING" }
      ]
    },
    {
      "collectionGroup": "leaderboards",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "region", "order": "ASCENDING" },
        { "fieldPath": "score", "order": "DESCENDING" }
      ]
    },
    {
      "collectionGroup": "arena_matches",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "status", "order": "ASCENDING" },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },

    /* ── Bilgi Ligi: 9 composite index (3 scope × 3 mode) ───────────────── */
    /*  scopeKey alanları:                                                  */
    /*    scopeWorld   = "{level}|{grade}"                                  */
    /*    scopeCountry = "{countryCode}|{level}|{grade}"                    */
    /*    scopeCity    = "{countryCode}|{cityCode}|{level}|{grade}"         */

    { "collectionGroup": "league_attempts", "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "scopeWorld", "order": "ASCENDING" },
        { "fieldPath": "score", "order": "DESCENDING" }
      ]
    },
    { "collectionGroup": "league_attempts", "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "scopeCountry", "order": "ASCENDING" },
        { "fieldPath": "score", "order": "DESCENDING" }
      ]
    },
    { "collectionGroup": "league_attempts", "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "scopeCity", "order": "ASCENDING" },
        { "fieldPath": "score", "order": "DESCENDING" }
      ]
    },

    { "collectionGroup": "league_attempts", "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "scopeWorld", "order": "ASCENDING" },
        { "fieldPath": "subjectKey", "order": "ASCENDING" },
        { "fieldPath": "score", "order": "DESCENDING" }
      ]
    },
    { "collectionGroup": "league_attempts", "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "scopeCountry", "order": "ASCENDING" },
        { "fieldPath": "subjectKey", "order": "ASCENDING" },
        { "fieldPath": "score", "order": "DESCENDING" }
      ]
    },
    { "collectionGroup": "league_attempts", "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "scopeCity", "order": "ASCENDING" },
        { "fieldPath": "subjectKey", "order": "ASCENDING" },
        { "fieldPath": "score", "order": "DESCENDING" }
      ]
    },

    { "collectionGroup": "league_attempts", "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "scopeWorld", "order": "ASCENDING" },
        { "fieldPath": "subjectKey", "order": "ASCENDING" },
        { "fieldPath": "topic", "order": "ASCENDING" },
        { "fieldPath": "score", "order": "DESCENDING" }
      ]
    },
    { "collectionGroup": "league_attempts", "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "scopeCountry", "order": "ASCENDING" },
        { "fieldPath": "subjectKey", "order": "ASCENDING" },
        { "fieldPath": "topic", "order": "ASCENDING" },
        { "fieldPath": "score", "order": "DESCENDING" }
      ]
    },
    { "collectionGroup": "league_attempts", "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "scopeCity", "order": "ASCENDING" },
        { "fieldPath": "subjectKey", "order": "ASCENDING" },
        { "fieldPath": "topic", "order": "ASCENDING" },
        { "fieldPath": "score", "order": "DESCENDING" }
      ]
    },

    /* ── Test havuzu (quiz_pool) ──────────────────────────────────────── */
    /*  poolKey = "{country}|{level}|{grade}|{subjectKey}|{topic}"          */
    /*  Random çekiş için createdAt veya rawIndex'e göre sıralı sorgular.   */
    { "collectionGroup": "quiz_pool", "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "poolKey", "order": "ASCENDING" },
        { "fieldPath": "createdAt", "order": "ASCENDING" }
      ]
    },

    /* ── Topluluk Özet Cache (summary_cache) ──────────────────────────── */
    /*  En yüksek puanlı adayı çekme (status=active, sort by ratings.avg)  */
    { "collectionGroup": "candidates", "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "status", "order": "ASCENDING" },
        { "fieldPath": "ratings.avg", "order": "DESCENDING" }
      ]
    },

    /* ── Question Pool ─────────────────────────────────────────────────── */
    /*  status=generating + acceptedCount<X scheduled scan için            */
    { "collectionGroup": "question_pool", "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "status", "order": "ASCENDING" },
        { "fieldPath": "acceptedCount", "order": "ASCENDING" }
      ]
    },
    /*  Frozen + eskimiş pool'ları taramak için                            */
    { "collectionGroup": "question_pool", "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "status", "order": "ASCENDING" },
        { "fieldPath": "frozenAt", "order": "ASCENDING" }
      ]
    },

    /* ── Sosyal: Arkadaşlık istekleri (inbox) ──────────────────────────── */
    /*  toUid altındaki inbox — status==pending + orderBy sentAt           */
    { "collectionGroup": "inbox", "queryScope": "COLLECTION_GROUP",
      "fields": [
        { "fieldPath": "status", "order": "ASCENDING" },
        { "fieldPath": "sentAt", "order": "DESCENDING" }
      ]
    },

    /* ── Sosyal: In-app bildirimler ────────────────────────────────────── */
    /*  items koleksiyonu — read==false unread sayımı için + orderBy when  */
    { "collectionGroup": "items", "queryScope": "COLLECTION_GROUP",
      "fields": [
        { "fieldPath": "read", "order": "ASCENDING" },
        { "fieldPath": "when", "order": "DESCENDING" }
      ]
    },

    /* ── league_attempts: arkadaş son aktivite stream'i ──────────────── */
    /*  where uid == X + orderBy when DESC                                 */
    { "collectionGroup": "league_attempts", "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "uid", "order": "ASCENDING" },
        { "fieldPath": "when", "order": "DESCENDING" }
      ]
    }
  ],
  "fieldOverrides": [
    {
      "collectionGroup": "users",
      "fieldPath": "email",
      "indexes": [
        { "queryScope": "COLLECTION", "order": "ASCENDING" }
      ]
    },
    {
      "collectionGroup": "users",
      "fieldPath": "searchTokens",
      "indexes": [
        { "queryScope": "COLLECTION", "arrayConfig": "CONTAINS" }
      ]
    }
  ]
}
